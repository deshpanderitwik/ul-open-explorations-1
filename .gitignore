# Secrets
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Rust build output (every candidate + the reference crate)
target/
**/target/

# Generated candidate crates are experiment scratch — only the seed (and any
# promoted winner) is tracked. The run history lives in archive/runs.jsonl.
candidates/gen-*

# Dashboard data is generated from the repo's records by dashboard/build.py
# (regenerated in CI before each Pages deploy) — not tracked.
dashboard/public/data.json

# Python
__pycache__/
*.pyc
.venv/

# OS / editor noise
.DS_Store
*.swp
.idea/
.vscode/
